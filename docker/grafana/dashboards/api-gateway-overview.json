{
  "title": "API Gateway — Overview",
  "uid": "rbac-gateway-overview",
  "tags": ["rbac-gateway", "api-gateway"],
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\"}[1m])) by (uri, method, status)",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "P95 / P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"api-gateway\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p95 — {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"api-gateway\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p99 — {{uri}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\", status=~\"4..\"}[1m]))",
          "legendFormat": "4xx errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "title": "Auth Failures / RBAC Denials / Rate Limit",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(gateway_auth_failures_total{application=\"api-gateway\"}[1m])",
          "legendFormat": "JWT Auth Failures (401)",
          "refId": "A"
        },
        {
          "expr": "rate(gateway_rbac_denied_total{application=\"api-gateway\"}[1m])",
          "legendFormat": "RBAC Denied (403)",
          "refId": "B"
        },
        {
          "expr": "rate(gateway_rate_limit_exceeded_total{application=\"api-gateway\"}[1m])",
          "legendFormat": "Rate Limit Exceeded (429)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "Circuit Breaker — State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{application=\"api-gateway\"}",
          "legendFormat": "{{name}} — {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Circuit Breaker — Fallback Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(gateway_circuit_breaker_fallback_total{application=\"api-gateway\"}[1m])",
          "legendFormat": "CB Fallbacks/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"api-gateway\"}",
          "legendFormat": "{{area}} — {{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 8,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"api-gateway\"}",
          "legendFormat": "Live threads",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"api-gateway\"}",
          "legendFormat": "Daemon threads",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 9,
      "title": "HikariCP — Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"api-gateway\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"api-gateway\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"api-gateway\"}",
          "legendFormat": "Pending",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 10,
      "title": "Redis — Command Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(spring_data_redis_command_seconds_bucket{application=\"api-gateway\"}[1m])) by (le, command)) * 1000",
          "legendFormat": "p95 {{command}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    }
  ]
}
