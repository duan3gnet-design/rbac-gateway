{
  "title": "k6 Performance Test",
  "uid": "k6-perf",
  "tags": ["k6", "performance"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Scenario",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "SHOW TAG VALUES FROM \"http_req_duration\" WITH KEY = \"scenario\"",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT sum(\"value\") FROM \"http_reqs\" WHERE $timeFilter",
          "alias": "Total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT non_negative_derivative(sum(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "alias": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT sum(\"value\") FROM \"http_req_failed\" WHERE $timeFilter",
          "alias": "errors"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active VUs",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time(5s) fill(previous)",
          "alias": "VUs"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter",
          "alias": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter",
          "alias": "p99"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate & Active VUs",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "VUs" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "query": "SELECT non_negative_derivative(sum(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "alias": "req/s"
        },
        {
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time(5s) fill(previous)",
          "alias": "VUs"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Response Time Percentiles (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 50) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "p50"
        },
        {
          "query": "SELECT percentile(\"value\", 90) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "p90"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "p95"
        },
        {
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "p99"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Status Breakdown",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rate-limited (429)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "circuit-breaker (503)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "query": "SELECT non_negative_derivative(sum(\"value\"), 1s) FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "alias": "errors"
        },
        {
          "query": "SELECT non_negative_derivative(sum(\"value\"), 1s) FROM \"errors_429_total\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "alias": "rate-limited (429)"
        },
        {
          "query": "SELECT non_negative_derivative(sum(\"value\"), 1s) FROM \"circuit_breaker_open_total\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "alias": "circuit-breaker (503)"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency by Endpoint (p95 ms)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE \"name\" = 'GET /api/resources/products' AND $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "products"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE \"name\" = 'GET /api/resources/orders' AND $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "orders"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE \"name\" = 'GET /api/resources/profile/whoami' AND $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "whoami"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE \"name\" = 'POST /api/auth/refresh' AND $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "auth/refresh"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE \"name\" = 'GET-admin' AND $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "admin"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Custom Metrics — Auth / Resource / Admin Latency",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"auth_latency_ms\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "auth p95"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"resource_latency_ms\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "resource p95"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"admin_latency_ms\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "admin p95"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"gateway_e2e_latency_ms\" WHERE $timeFilter GROUP BY time(10s) fill(null)",
          "alias": "gateway e2e p95"
        }
      ]
    }
  ]
}
