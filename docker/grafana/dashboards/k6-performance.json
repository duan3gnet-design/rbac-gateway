{
  "title": "k6 Performance Test",
  "uid": "k6-perf",
  "tags": ["k6", "performance"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_reqs",
        "select": [[
          { "type": "field",  "params": ["value"] },
          { "type": "sum",    "params": [] }
        ]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_reqs",
        "select": [[
          { "type": "field",                       "params": ["value"] },
          { "type": "sum",                         "params": [] },
          { "type": "non_negative_derivative",     "params": ["1s"] }
        ]],
        "groupBy": [
          { "type": "time", "params": ["$__interval"] },
          { "type": "fill", "params": ["0"] }
        ],
        "tags": []
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_req_failed",
        "select": [[
          { "type": "field", "params": ["value"] },
          { "type": "mean",  "params": [] }
        ]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Active VUs",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "vus",
        "select": [[
          { "type": "field", "params": ["value"] },
          { "type": "last",  "params": [] }
        ]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red",    "value": 2000 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_req_duration",
        "select": [[
          { "type": "field",      "params": ["value"] },
          { "type": "percentile", "params": ["95"] }
        ]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red",    "value": 5000 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_req_duration",
        "select": [[
          { "type": "field",      "params": ["value"] },
          { "type": "percentile", "params": ["99"] }
        ]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate & Active VUs",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [{
          "matcher": { "id": "byName", "options": "vus" },
          "properties": [
            { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
          ]
        }]
      },
      "targets": [
        {
          "refId": "A",
          "alias": "req/s",
          "resultFormat": "time_series",
          "measurement": "http_reqs",
          "select": [[
            { "type": "field",                   "params": ["value"] },
            { "type": "sum",                     "params": [] },
            { "type": "non_negative_derivative", "params": ["1s"] }
          ]],
          "groupBy": [
            { "type": "time", "params": ["$__interval"] },
            { "type": "fill", "params": ["0"] }
          ],
          "tags": []
        },
        {
          "refId": "B",
          "alias": "vus",
          "resultFormat": "time_series",
          "measurement": "vus",
          "select": [[
            { "type": "field", "params": ["value"] },
            { "type": "last",  "params": [] }
          ]],
          "groupBy": [
            { "type": "time", "params": ["$__interval"] },
            { "type": "fill", "params": ["previous"] }
          ],
          "tags": []
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Response Time Percentiles (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "refId": "A", "alias": "p50",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["50"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "B", "alias": "p90",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["90"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "C", "alias": "p95",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "D", "alias": "p99",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["99"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Status Breakdown",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rate-limited 429" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "circuit-breaker 503" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A", "alias": "errors",
          "resultFormat": "time_series",
          "measurement": "http_req_failed",
          "select": [[
            { "type": "field", "params": ["value"] },
            { "type": "sum",   "params": [] },
            { "type": "non_negative_derivative", "params": ["1s"] }
          ]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "B", "alias": "rate-limited 429",
          "resultFormat": "time_series",
          "measurement": "errors_429_total",
          "select": [[
            { "type": "field", "params": ["value"] },
            { "type": "sum",   "params": [] },
            { "type": "non_negative_derivative", "params": ["1s"] }
          ]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "C", "alias": "circuit-breaker 503",
          "resultFormat": "time_series",
          "measurement": "circuit_breaker_open_total",
          "select": [[
            { "type": "field", "params": ["value"] },
            { "type": "sum",   "params": [] },
            { "type": "non_negative_derivative", "params": ["1s"] }
          ]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency by Endpoint (p95 ms)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "refId": "A", "alias": "products",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": [{ "key": "name", "operator": "=", "value": "GET /api/resources/products" }]
        },
        {
          "refId": "B", "alias": "orders",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": [{ "key": "name", "operator": "=", "value": "GET /api/resources/orders" }]
        },
        {
          "refId": "C", "alias": "whoami",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": [{ "key": "name", "operator": "=", "value": "GET-whoami" }]
        },
        {
          "refId": "D", "alias": "auth/refresh",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": [{ "key": "name", "operator": "=", "value": "POST-auth-refresh" }]
        },
        {
          "refId": "E", "alias": "admin",
          "resultFormat": "time_series",
          "measurement": "http_req_duration",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": [{ "key": "name", "operator": "=", "value": "GET-admin" }]
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Custom Metrics — Auth / Resource / Admin / Gateway e2e (p95 ms)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "refId": "A", "alias": "auth p95",
          "resultFormat": "time_series",
          "measurement": "auth_latency_ms",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "B", "alias": "resource p95",
          "resultFormat": "time_series",
          "measurement": "resource_latency_ms",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "C", "alias": "admin p95",
          "resultFormat": "time_series",
          "measurement": "admin_latency_ms",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        },
        {
          "refId": "D", "alias": "gateway e2e p95",
          "resultFormat": "time_series",
          "measurement": "gateway_e2e_latency_ms",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "percentile", "params": ["95"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["null"] }],
          "tags": []
        }
      ]
    },

    {
      "id": 12,
      "type": "row",
      "title": "Error Analysis",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Error Rate by Type (per second)",
      "description": "So sánh tốc độ lỗi theo từng loại theo thời gian. Spike ở 429 = rate limit đang trigger, spike ở 503 = circuit breaker đang mở.",
      "gridPos": { "x": 0, "y": 29, "w": 16, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "401 Unauthorized" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "403 Forbidden" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "429 Rate Limited" },
            "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx Server Error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "503 Circuit Breaker" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A", "alias": "401 Unauthorized",
          "resultFormat": "time_series",
          "measurement": "errors_401_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "B", "alias": "403 Forbidden",
          "resultFormat": "time_series",
          "measurement": "errors_403_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "C", "alias": "429 Rate Limited",
          "resultFormat": "time_series",
          "measurement": "errors_429_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "D", "alias": "5xx Server Error",
          "resultFormat": "time_series",
          "measurement": "errors_5xx_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "E", "alias": "503 Circuit Breaker",
          "resultFormat": "time_series",
          "measurement": "circuit_breaker_open_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        },
        {
          "refId": "F", "alias": "Total Logged Errors",
          "resultFormat": "time_series",
          "measurement": "error_logged_total",
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "sum", "params": [] }, { "type": "non_negative_derivative", "params": ["1s"] }]],
          "groupBy": [{ "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["0"] }],
          "tags": []
        }
      ]
    },

    {
      "id": 14,
      "type": "gauge",
      "title": "Current Error Rate",
      "description": "Tỷ lệ request lỗi hiện tại. Ngưỡng: xanh < 1%, vàng < 5%, đỏ ≥ 5%.",
      "gridPos": { "x": 16, "y": 29, "w": 4, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "http_req_failed",
        "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Success Rate",
      "description": "Tỷ lệ request thành công (2xx). Mục tiêu > 95%.",
      "gridPos": { "x": 20, "y": 29, "w": 4, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.90 },
              { "color": "green",  "value": 0.95 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "resultFormat": "time_series",
        "measurement": "success_rate",
        "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
        "groupBy": [],
        "tags": []
      }]
    },

    {
      "id": 16,
      "type": "stat",
      "title": "Total Errors by Type",
