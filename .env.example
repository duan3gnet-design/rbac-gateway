# ============================================================
# .env.example — copy thành .env trước khi chạy
# ============================================================

# Database credentials (dùng chung cho tất cả databases)
DB_USERNAME=postgres
DB_PASSWORD=12345

# Database URLs cho từng service (local dev)
AUTH_DB_URL=jdbc:postgresql://localhost:5432/rbac_auth
RESOURCE_DB_URL=jdbc:postgresql://localhost:5432/rbac_resource
GATEWAY_DB_URL=jdbc:postgresql://localhost:5432/rbac_gateway

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (base64 encoded secret — giữ nguyên hoặc generate mới)
JWT_SECRET=bXlfc3VwZXJfc2VjcmV0X2tleV9mb3JfcmJhY19nYXRld2F5XzIwMjQ=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Internal service-to-service secret (dùng chung giữa auth-service và resource-service)
INTERNAL_SECRET=changeme-internal-secret

# TRACING (Micrometer + OTLP → Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=rbac-jaeger:4317

# k6 Performance Test (docker compose --profile perf)
# Credentials k6 dùng để register/login trong setup()
K6_ADMIN_USERNAME=k6admin
K6_ADMIN_PASSWORD=Admin@123
K6_USER_USERNAME=k6user
K6_USER_PASSWORD=User@123
# Profile: SMOKE | LOAD | STRESS | SOAK | SPIKE | BREAKPOINT
K6_TEST_PROFILE=LOAD
# Scenario file (relative path, không dùng /scripts/ prefix để tránh Git Bash convert)
K6_SCRIPT=scenarios/full-system.js